{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {
        "PLAYWRIGHT_BROWSERS_PATH": "0",
        "PLAYWRIGHT_HEADLESS": "false",
        "PLAYWRIGHT_BASE_URL": "http://localhost:3000"
      }
    }
  }
}
