// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      DeconstructionSession[]

  @@index([email])
}

model DeconstructionSession {
  id                String   @id @default(cuid())
  userId            String
  title             String
  rootObjectName    String
  rootObjectIcon    String?
  rootObjectImage   String?

  // Store the entire tree as JSON
  treeData          Json

  // Store full identification result
  identificationResult Json?

  // Store prompt settings
  promptSettings    Json?

  // Store breakdown mode (basic or production)
  breakdownMode     String?

  // Store knowledge card cache
  knowledgeCache    Json?

  // Store node positions for graph view
  nodePositions     Json?

  // Metadata
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastAccessedAt    DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 生产分析进度（每个节点独立）
  productionAnalysisProgress ProductionAnalysisProgress[]

  @@index([userId, updatedAt])
  @@index([userId, lastAccessedAt])
}

// 生产分析进度
model ProductionAnalysisProgress {
  id                    String   @id @default(cuid())
  sessionId             String
  partId                String
  partName              String

  // 当前步骤
  currentStep           String   @default("product-planning")

  // 产品规划和竞品分析
  productPlan           Json?
  competitorAnalysis    Json?

  // 供应商信息
  suppliers             Json?
  selectedSupplier      Json?

  // 定制问题
  customizationQuestions Json?
  customizationAnswers  Json?

  // 工艺方案
  processes             Json?
  selectedProcess       Json?

  // 分析结果
  analysisResult        Json?

  // 最终报告
  finalReport          Json?

  // 是否完成
  isCompleted           Boolean  @default(false)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  session              DeconstructionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, partId])
}

// 模板会话（用于路演的预设案例）
model TemplateSession {
  id                String   @id @default(cuid())

  // 模板基本信息
  templateKey       String   @unique  // 用于关键词匹配，如 "mechanical-keyboard"
  displayName       String              // 显示名称，如 "客制化机械键盘"
  category          String              // 分类：大国重器、极客定制、生活黑科技、绿色新消费
  keywords          String              // 关键词列表（JSON数组），用于匹配用户输入

  // 识别结果
  identificationResult Json             // IdentificationResponse 格式

  // 完整拆解树
  treeData          Json                // 完整的节点和边数据
  nodePositions     Json?               // React Flow 节点位置

  // 7 个多智能体分析报告
  agentReports      Json                // 包含所有智能体分析结果

  // 生产分析数据（预设）
  productionAnalysis Json?              // 预设的生产分析结果

  // 元数据
  priority          Int      @default(0)  // 优先级（用于匹配冲突时）
  isActive          Boolean  @default(true)  // 是否启用
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([templateKey])
  @@index([category])
}
